---
import { Image } from 'astro:assets';
import { images } from '../assets/images';
---

<section class="apply" id="apply" aria-label="Apply to join Wonderever">
  <div class="apply-photo-wrap">
    <Image
      src={images.y2025.src}
      alt={images.y2025.alt}
      width={1600}
      class="apply-photo"
    />
    <div class="apply-photo-overlay"></div>
  </div>

  <div class="apply-content">
    <p class="apply-label">Elsewhere 2026 · July 7–12</p>
    <h2 class="apply-heading">Are you<br />one of us?</h2>
    <p class="apply-body">
      We're looking for ~40 co-creators. You'll build and strike the camp,
      lead shifts, cook, make art, and hold the space. You'll also get to be
      part of one of the best-kept secrets on the playa.
    </p>
    <p class="apply-body apply-body--note">
      If you're a Somebody with Nobody energy, this might be your barrio.
    </p>

    <a
      href="https://docs.google.com/forms/d/e/1FAIpQLSf47eikyRyJv_UiQxbgP4WL_ujqcO7Git-9PqrA-ziu2_j6Lw/viewform"
      class="apply-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      Become a Wonderling
    </a>

    <p class="apply-contact">
      Questions?&nbsp;
      <a href="mailto:wondereverbarrio@gmail.com">wondereverbarrio@gmail.com</a>
    </p>

    <footer class="apply-footer">
      <p>Wonderever · a barrio at <a href="https://nobodies.team/" target="_blank" rel="noopener noreferrer">Elsewhere</a></p>
      <p>© Wonderever 2026</p>
    </footer>
  </div>
</section>

<style>
  .apply {
    position: relative;
    overflow: hidden;
    min-height: 92vh;
    display: flex;
    align-items: center;
  }

  .apply-photo-wrap {
    position: absolute;
    inset: 0;
  }

  .apply-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .apply-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      oklch(0.74 0.09 75 / 0.90),
      oklch(0.82 0.11 78 / 0.94)
    );
  }

  .apply-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 6vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  .apply-label {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: oklch(0.30 0.05 65);
    margin: 0 0 1.5rem;
  }

  .apply-heading {
    font-family: 'Bungee', sans-serif;
    font-size: clamp(3rem, 9vw, 8rem);
    color: oklch(0.11 0.04 60);
    line-height: 0.95;
    margin: 0 0 clamp(1.5rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
  }

  .apply-body {
    font-family: 'Jost', sans-serif;
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    line-height: 1.75;
    color: oklch(0.22 0.04 62);
    max-width: 52ch;
    margin: 0 0 1rem;
  }

  .apply-body--note {
    font-style: italic;
    color: oklch(0.30 0.04 62);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .apply-cta {
    display: inline-block;
    background: oklch(0.11 0.04 60);
    color: oklch(0.92 0.008 80);
    font-family: 'Bungee', sans-serif;
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    letter-spacing: 0.04em;
    text-decoration: none;
    padding: 1.05rem 2.75rem;
    transition: background 0.18s cubic-bezier(0.25, 1, 0.5, 1),
                color 0.18s cubic-bezier(0.25, 1, 0.5, 1);
    min-height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .apply-cta:hover {
    background: oklch(0.62 0.26 322);
    color: oklch(0.97 0.008 80);
  }

  .apply-footer a {
    color: oklch(0.38 0.04 65);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .apply-contact {
    font-family: 'Jost', sans-serif;
    font-size: 0.875rem;
    color: oklch(0.30 0.04 65);
    margin: 1.5rem 0 0;
  }

  .apply-contact a {
    color: oklch(0.18 0.04 62);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .apply-footer {
    margin-top: clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .apply-footer p {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: oklch(0.38 0.04 65);
    margin: 0;
  }
</style>
